# 预发布环境配置
# 此文件可提交到 Git

# 应用环境标识
VITE_APP_ENV=staging

# 构建时间戳
VITE_BUILD_TIME=

# API 配置
# VITE_API_URL=https://staging-api.example.com/api

# 调试模式（预发布环境启用）
VITE_DEBUG=true

# 功能开关
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_CHAT=true
VITE_ENABLE_COMMUNITY=true

# 分析工具（预发布环境）
# VITE_ANALYTICS_ID=UA-XXXXX-Y