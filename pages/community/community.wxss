.post {
  padding: 20rpx;
  margin-top: 18rpx;
}

.post__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.post__userRow {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.post__avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: var(--surface-2);
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  color: rgba(15, 23, 42, 0.86);
}

.post__user {
  font-size: 28rpx;
  font-weight: 700;
}

.post__time {
  font-size: 22rpx;
  color: var(--color-muted);
}

.post__content {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(15, 23, 42, 0.90);
}

.post__meta {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  color: var(--color-muted);
  font-size: 24rpx;
}

.post__tag {
  color: var(--color-accent);
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(22, 163, 74, 0.18);
  background: rgba(22, 163, 74, 0.08);
}

.post__dot {
  opacity: 0.55;
}

.post__muted {
  opacity: 0.9;
}
