.list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.empty {
  padding: 26rpx;
  margin-top: 18rpx;
}

.empty__title {
  font-size: 32rpx;
  font-weight: 700;
}

.empty__desc {
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.6;
}

.empty__btn {
  margin-top: 18rpx;
}

.product {
  transition: transform 160ms ease;
}

.product:active {
  transform: scale(0.99);
}

.product__inner {
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
}

.product__imgWrap {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: var(--surface-2);
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.product__img {
  width: 92rpx;
  height: 92rpx;
}

.product__main {
  flex: 1;
  min-width: 0;
}

.product__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.product__left {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.product__brand {
  font-size: 28rpx;
  font-weight: 900;
}

.product__tag {
  font-size: 22rpx;
  color: var(--color-accent);
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(22, 163, 74, 0.18);
  background: rgba(22, 163, 74, 0.08);
}

.product__name {
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 8rpx;
  line-height: 1.2;
}

.product__price {
  font-size: 26rpx;
  color: var(--color-muted);
  font-weight: 600;
}

.product__right {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.product__remove {
  padding: 8rpx 12rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(239, 68, 68, 0.28);
  background: rgba(239, 68, 68, 0.08);
  color: rgba(239, 68, 68, 0.92);
  font-size: 22rpx;
}

.product__desc {
  margin-top: 10rpx;
  color: rgba(15, 23, 42, 0.86);
  font-size: 24rpx;
  line-height: 1.6;
}
