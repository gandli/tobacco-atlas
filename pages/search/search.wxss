.searchBox {
  margin-top: 12rpx;
  padding: 14rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.searchBox__input {
  flex: 1;
  height: 70rpx;
  padding: 0 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--color-border);
  background: var(--surface-2);
  color: var(--color-text);
  font-size: 26rpx;
}

.searchBox__placeholder {
  color: rgba(107, 114, 128, 0.75);
}

.searchBox__btn {
  background: var(--color-accent);
  color: #fff;
  border-radius: 16rpx;
  padding: 10rpx 18rpx;
}

.list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item {
  transition: transform 160ms ease;
}

.item:active {
  transform: scale(0.99);
}

.item__inner {
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
}

.item__imgWrap {
  width: 112rpx;
  height: 112rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: var(--surface-2);
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.item__img {
  width: 86rpx;
  height: 86rpx;
}

.item__main {
  flex: 1;
  min-width: 0;
}

.item__head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
}

.item__title {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  min-width: 0;
}

.item__brand {
  font-size: 28rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.item__name {
  font-size: 28rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item__price {
  font-size: 26rpx;
  color: var(--color-muted);
  font-weight: 600;
}

.item__meta {
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.item__tag {
  color: var(--color-accent);
}

.item__dot {
  opacity: 0.55;
}

.item__muted {
  opacity: 0.95;
}

.item__desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(15, 23, 42, 0.86);
}

.empty {
  margin-top: 18rpx;
  padding: 20rpx;
}

.empty__title {
  font-size: 30rpx;
  font-weight: 700;
}

.empty__desc {
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.7;
}
