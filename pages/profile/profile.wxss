.panel {
  padding: 18rpx;
  margin-top: 18rpx;
}

.panel__title {
  font-size: 28rpx;
  font-weight: 900;
  margin-bottom: 6rpx;
}

.panel__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 6rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.panel__row:last-child {
  border-bottom: none;
}

.panel__label {
  font-size: 26rpx;
  color: rgba(15, 23, 42, 0.92);
}

.panel__value {
  font-size: 24rpx;
  color: var(--color-muted);
}

.panel__desc {
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.7;
}

.panel__row--link:active {
  opacity: 0.78;
}

.panel__chev {
  font-size: 28rpx;
  color: rgba(15, 23, 42, 0.36);
  margin-left: 6rpx;
}
