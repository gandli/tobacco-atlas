.heroBanner {
  padding: 18rpx;
  margin-top: 12rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, rgba(22, 163, 74, 0.08), rgba(22, 163, 74, 0.03));
}

.heroBanner__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.heroBanner__title {
  font-size: 40rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.heroBanner__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.heroBanner__sub {
  font-size: 22rpx;
  color: var(--color-muted);
}

.heroBanner__pill {
  padding: 8rpx 12rpx;
}

.heroBanner__swiper {
  margin-top: 14rpx;
  height: 210rpx;
}

.heroBanner__item {
  height: 100%;
  padding: 10rpx 10rpx 12rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 10rpx 22rpx rgba(15, 23, 42, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.heroBanner__imgWrap {
  width: 92rpx;
  height: 92rpx;
  border-radius: 22rpx;
  background: var(--surface-2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.heroBanner__img {
  width: 72rpx;
  height: 72rpx;
}

.heroBanner__brand {
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.heroBanner__name {
  font-size: 22rpx;
  color: var(--color-muted);
  text-align: center;
  line-height: 1.2;
  max-height: 52rpx;
  overflow: hidden;
}

.seg {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
  margin-bottom: 18rpx;
}

.seg__item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 16rpx;
  border: 1rpx solid var(--color-border);
  background: var(--surface-2);
  color: var(--color-muted);
  transition: all 180ms ease;
}

.seg__item--on {
  background: rgba(22, 163, 74, 0.12);
  border-color: rgba(22, 163, 74, 0.26);
  color: rgba(15, 23, 42, 0.92);
}

.list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product {
  transform: translateZ(0);
  transition: transform 160ms ease, border-color 160ms ease;
}

.product:active {
  transform: scale(0.99);
  border-color: rgba(15, 23, 42, 0.18);
}

.product__inner {
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
}

.product__imgWrap {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: var(--surface-2);
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.product__img {
  width: 92rpx;
  height: 92rpx;
}

.product__main {
  flex: 1;
  min-width: 0;
}

.product__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.product__right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.product__brand {
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 0.5rpx;
}

.product__fav {
  width: 64rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.08);
  background: rgba(255, 255, 255, 0.9);
}

.product__favIcon {
  color: rgba(107, 114, 128, 0.78);
  font-size: 30rpx;
  transition: transform 160ms ease, color 160ms ease;
}

.product__favIcon--on {
  color: var(--color-accent);
  transform: scale(1.05);
}

.product__name {
  font-size: 32rpx;
  font-weight: 700;
  margin-top: 6rpx;
  line-height: 1.2;
}

.product__price {
  font-size: 26rpx;
  color: var(--color-muted);
  font-weight: 600;
}

.product__meta {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: var(--color-muted);
  font-size: 24rpx;
}

.product__dot {
  opacity: 0.6;
}

.product__desc {
  margin-top: 10rpx;
  color: rgba(15, 23, 42, 0.84);
  font-size: 24rpx;
  line-height: 1.6;
}

.footer-space {
  height: 36rpx;
}
